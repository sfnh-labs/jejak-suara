# Neon Postgres connection string
# Get yours at https://console.neon.tech → your project → connection string
DATABASE_URL="postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Closed launch: password-protect the entire site with HTTP Basic Auth
# Set to "true" and provide credentials to enable.
# Format for BASIC_AUTH_CREDENTIALS: "username:password"
# CLOSED_LAUNCH=true
# BASIC_AUTH_CREDENTIALS="invited:rahasia123"
